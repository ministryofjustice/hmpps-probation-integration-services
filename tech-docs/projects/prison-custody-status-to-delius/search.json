ef":11,"tf":0.15822784810126583}}}}},"o":{"docs":{"11":{"ref":11,"tf":2.689873417721519}}},"r":{"docs":{},"e":{"docs":{},"e":{"docs":{"11":{"ref":11,"tf":0.15822784810126583}}}},"i":{"docs":{},"g":{"docs":{},"g":{"docs":{},"e":{"docs":{},"r":{"docs":{},"s":{"docs":{"11":{"ref":11,"tf":0.15822784810126583}}}}}}}}},"y":{"docs":{},"p":{"docs":{},"e":{"docs":{"11":{"ref":11,"tf":0.4746835443037975}},"s":{"docs":{"11":{"ref":11,"tf":0.31645569620253167}}}}}}},"u":{"docs":{},"i":{"docs":{"11":{"ref":11,"tf":0.15822784810126583}}},"p":{"docs":{},"d":{"docs":{},"a":{"docs":{},"t":{"docs":{},"e":{"docs":{"11":{"ref":11,"tf":0.31645569620253167}}}}}}},"s":{"docs":{},"e":{"docs":{"11":{"ref":11,"tf":0.15822784810126583}},"d":{"docs":{"11":{"ref":11,"tf":0.15822784810126583}}}},"i":{"docs":{},"n":{"docs":{},"g":{"docs":{"11":{"ref":11,"tf":0.15822784810126583}}}}}}},"v":{"docs":{},"i":{"docs":{},"a":{"docs":{"11":{"ref":11,"tf":0.15822784810126583}}}}},"w":{"docs":{},"e":{"docs":{"11":{"ref":11,"tf":0.7911392405063291}}},"h":{"docs":{},"e":{"docs":{},"n":{"docs":{"11":{"ref":11,"tf":0.31645569620253167}}},"t":{"docs":{},"h":{"docs":{},"e":{"docs":{},"r":{"docs":{"11":{"ref":11,"tf":0.15822784810126583}}}}}}},"i":{"docs":{},"c":{"docs":{},"h":{"docs":{"11":{"ref":11,"tf":0.15822784810126583}}}}}},"i":{"docs":{},"t":{"docs":{},"h":{"docs":{"11":{"ref":11,"tf":0.15822784810126583}}}}}}},"length":143},"corpusTokens":["a","able","about","accurately","activity","add","additionalinformation","admission","adult","all","allocate","also","and","any","api","are","as","attribute","audit","be","business","by","calls","case","change","changes","class","code","combination","contacts","contained","context","correct","create","current","currently","custodial","custody","database","delius","details","determine","development","domain","end","ensure","establishment","event","events","events.prisoner.received","events.prisoner.released","eventtype","example","field","filter","filtered","following","for","formats","from","history","hmpps","iaps","in","inbound","incoming","information","ingested","inspection","interfaces","into","is","licence","licenceconditions","location","logs","made","maintained","manually","map","message","messages","move","necessary","need","needed","nomis","not","notification","notified","of","offender","on","or","out","person","person’s","policy","practitioners","prison","probation","process","queue","raised","reason","recall","recalled","recorded","records","release","released","removing","responds","responsibleofficer","service","source","specific","sqs","status","suitable","terminate","test","tested","that","the","they","this","to","tree","triggers","type","types","ui","update","use","used","using","via","we","when","whether","which","with"],"pipeline":["trimmer"]}, "docs": {"11":{"title":"About","content":"Prison Custody Status to Delius\nInbound service that responds to events raised when the custody status of a\nperson in prison changes. The service is notified when a person is released\nfrom prison or a person is recalled to prison. The information about the\nspecific type of custody status is contained in the notification message. This\nis used to add and update Custody and Event records in Delius to ensure\nthe correct case history is maintained and the person’s current location is\naccurately recorded. We also create any necessary Contacts, terminate\nLicenceConditions and allocate the person to a ResponsibleOfficer as\nneeded. We also add the necessary audit logs and IAPS events.\nProbation Business Need\nRemoving the need for Probation Practitioners to manually update Delius with\nthe custody status of a person as they move in and out of prison.\nContext Map\n\nInterfaces\nMessage Formats\nThe service responds to HMPPS Domain Event messages via the\nHMPPS Prison Custody Status to Delius Queue\nThe events are raised by the Prison Offender Events service,\nwhich responds to changes made in the NOMIS database.\nExample messages are in the development source tree.\nIncoming messages are filtered on the eventType attribute by the SQS queue policy.\nEvent Triggers\n\n        \n          \nBusiness Event\nMessage Class\nMessage Event Type / Filter\n\nRelease from Prison\nHMPPS Domain Event\nprison-offender-events.prisoner.released\n\nRecall to Prison\nHMPPS Domain Event\nprison-offender-events.prisoner.received\n\n        \n      Custody Status Details\nAs we are not able to process all types of custody activity we use the details\nin the  additionalInformation field to determine whether the specific\nnotification is suitable to be ingested into Delius. Currently we are able to\nprocess the following custody change types:\n\n        \n          \nCustody Change\nType\nReason Code\n\nRelease\nReleased on Adult Licence\nRELEASED\n\nRecall\nRecall Notified by Custodial Establishment\nADMISSION\n\n        \n      End-to-End Test\nThe service is end-to-end tested\nusing a combination of Prison API calls and Delius UI inspection.\n","url":"/"}}}