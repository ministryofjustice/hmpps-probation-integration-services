":{"docs":{},"s":{"docs":{"11":{"ref":11,"tf":0.19011406844106463}}}}},"o":{"docs":{"11":{"ref":11,"tf":1.9011406844106464}},"p":{"docs":{},"i":{"docs":{},"c":{"docs":{"11":{"ref":11,"tf":1.1406844106463878}}}}}}},"u":{"docs":{},"p":{"docs":{"11":{"ref":11,"tf":0.38022813688212925}}},"r":{"docs":{},"l":{"docs":{"11":{"ref":11,"tf":0.19011406844106463}},"=":{"docs":{},"h":{"docs":{},"t":{"docs":{},"t":{"docs":{},"p":{"docs":{"11":{"ref":11,"tf":0.7604562737642585}}}}}}}}},"s":{"docs":{},"e":{"docs":{"11":{"ref":11,"tf":0.5703422053231939}},"d":{"docs":{"11":{"ref":11,"tf":0.19011406844106463}}}},"i":{"docs":{},"n":{"docs":{},"g":{"docs":{"11":{"ref":11,"tf":0.38022813688212925}}}}}}},"v":{"docs":{},"a":{"docs":{},"l":{"docs":{},"i":{"docs":{},"d":{"docs":{},"a":{"docs":{},"t":{"docs":{},"e":{"docs":{},"d":{"docs":{"11":{"ref":11,"tf":0.19011406844106463}}}}}}}},"u":{"docs":{},"e":{"docs":{},"s":{"docs":{"11":{"ref":11,"tf":0.19011406844106463}}}}}},"r":{"docs":{},"i":{"docs":{},"a":{"docs":{},"b":{"docs":{},"l":{"docs":{},"e":{"docs":{},"s":{"docs":{"11":{"ref":11,"tf":0.19011406844106463}}}}}}}}}}},"w":{"docs":{},"e":{"docs":{},"s":{"docs":{},"t":{"docs":{"11":{"ref":11,"tf":0.9505703422053232}}}}},"i":{"docs":{},"l":{"docs":{},"l":{"docs":{"11":{"ref":11,"tf":0.38022813688212925}}}},"t":{"docs":{},"h":{"docs":{"11":{"ref":11,"tf":0.19011406844106463}}}}}}},"length":124},"corpusTokens":["000000000000","10","2","2:000000000000:offender","a","about","access","activemq","add","and","any","app","application","are","arn","arn:aws:sns:eu","aws","based","bash","be","before","bin","by","can","changes","check","class","cli","cloud_aws_sqs_endpoint=http","cloud_aws_sqs_region=eu","compose","configure","connect","connected","container","create","d","database","default","delius","desired","dev","development","docker","endpoint","environment","eu","events","exec","file","following","for","h2","http","id","if","in","instance","instructions","is","it","jms","just","key","localhost:4566","localstack","max","means","message","messages","messaging_producer_topic=arn:aws:sns:eu","name","national","necessary","not","notification","number","of","offender","on","only","or","outbound","path","project","protocol","provided","published","queue","receive","reflect","region","required","run","running","secret","send","sending","service","services","shell","sns","so","sqs","start","starting","subscribe","sufficient","the","this","to","topic","up","url","url=http","use","used","using","validated","values","variables","west","will","with"],"pipeline":["trimmer"]}, "docs": {"11":{"title":"About","content":"offender-events-and-delius\nOutbound Service sending offender events based on changes in National Delius.\nDev Instructions\nBy default, offender-events will use the ActiveMQ (JMS) queue to send messages for development. \nThis means just starting the application using the dev class path is sufficient to run the database (H2) and outbound message queue.\nUsing LocalStack\nIf desired, the app can be connected to a localstack instance to reflect the AWS SNS topic.\nUse the docker-compose file provided with the project to start up localstack services in a container\ndocker-compose up -d\nFor the following connect to the shell of the container \nshell\ndocker exec -it localstack /bin/bash\n\nIt will be necessary to configure the aws cli before use. The values are not validated so any access key id or access secret can be used.\naws configure\nCreate the topic:\naws --endpoint-url=http://localhost:4566 sns create-topic --name offender-events --region eu-west-2\nCreate a queue:\naws --endpoint-url=http://localhost:4566 sqs create-queue --queue-name offender-events --region eu-west-2\nSubscribe the queue to the topic to receive messages published to the topic:\naws --endpoint-url=http://localhost:4566 sns subscribe \\\n--topic-arn arn:aws:sns:eu-west-2:000000000000:offender-events \\\n--protocol sqs \\\n--notification-endpoint http://localhost:4566/000000000000/offender-events\nCheck for messages\naws --endpoint-url=http://localhost:4566 sqs receive-message \\\n--queue-url http://localhost:4566/000000000000/offender-events \\\n--max-number-of-messages 10\nAdd the following environment variables before running the application:\nMESSAGING_PRODUCER_TOPIC=arn:aws:sns:eu-west-2:000000000000:offender-events\nCLOUD_AWS_SQS_REGION=eu-west-2 # for localstack only - not required in AWS\nCLOUD_AWS_SQS_ENDPOINT=http://localhost:4566 # for localstack only - not required in AWS\n","url":"/"}}}