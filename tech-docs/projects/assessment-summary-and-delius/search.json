27791563275436}}}},"t":{"docs":{},"h":{"docs":{"11":{"ref":11,"tf":0.12406947890818859}},"i":{"docs":{},"n":{"docs":{"11":{"ref":11,"tf":0.12406947890818859}}}}}}},"o":{"docs":{},"r":{"docs":{},"k":{"docs":{},"f":{"docs":{},"l":{"docs":{},"o":{"docs":{},"w":{"docs":{"11":{"ref":11,"tf":0.12406947890818859}},"s":{"docs":{"11":{"ref":11,"tf":0.12406947890818859}}}}}}}}}}}},"length":161},"corpusTokens":["a","about","active","added","against","all","an","and","any","api","app","are","as","assess","assessment","assessment.scores.determined","assessment.summary.produced","asyncapi","attribute","basis","be","been","being","business","by","can","cannot","categorised","change","checked","communicate","compared","conducted","configured","considered","context","created","creation","data","database","date","deleted","delius","dependencies","deregistration","deregistrations","development","document.queryselector('main').parentelement.appendchild(document.queryselector('main","domain","evaluated","event","events","eventtype","example","existing","filtered","for","formats","from","full","generated","harm","has","having","hmpps","identified","iframe","in","incoming","infer","information","interfaces","into","is","latest","level","levels","listens","log","longer","low","maintained","manually","map","message","messages","need","needs","new","no","note","oasys","of","on","or","ords","other","overview","pane__content","person","person’s","policy","position","previous","produced","provide","queue","quick","raised","record","recorded","reduces","reference","registration","registrations","regular","relative","relies","replaced","required","responds","result","retrieved","retrieving","risk","risks","rosh","second","sentenced","serious","service","so","some","source","sqs","stored","submitted","summaries","summary","system","the","their","this","to","tree","type","types","typically","up","updated","used","users","via","when","which","who","will","with","within","workflow","workflows"],"pipeline":["trimmer"]}, "docs": {"11":{"title":"About","content":"Assessment Summary and Delius\nThis service listens to domain events when a new assessment has been produced in the OASys system. The assessment is conducted for a person who has been sentenced to assess their needs and risks. Delius will record a summary of the assessment.\nWhen any new risks are identified or a change to an existing risk level, a new registration is generated. Existing registrations which are no longer required or considered to be a low risk are recorded as deregistrations.\nThe risks are categorised as:\n\n\nRisk of serious harm (RoSH)\nOther risks\n\nNote: The service cannot infer all types of risk from the assessment summary. Some risk registrations are manually added and maintained in Delius.\nBusiness need\nThe users typically log into Delius on a regular basis so the assessment summaries and registrations provide a quick overview of the person and risk level. This reduces the need of users having to log into a second system (OASys).\nData dependencies\nAssessment summary relies on the OASys ORDS API for retrieving the assessment summary and RoSH summary. The summary data is compared against the risk levels configured within the Delius database, and the result is used to updated the registration data. The service relies on Delius data for up to date information on a person’s latest assessment and active registrations.\nContext Map - Assessment Summary Data\n\nWorkflows\nAssessment summary produced workflow\nThe assessment summary is recorded in Delius. The risks are evaluated and stored as registrations.\n\n        \n          \nBusiness Event\nMessage Attribute Event Type\nMessage Event Type\n\nAssessment submitted\nrisk-assessment.scores.determined\nassessment.summary.produced\n\n        \n      Record assessment\nThe previous assessment summary is deleted and replaced with the new assessment summary. The full assessment can be retrieved from OASys.\n\nRecord risks\nThe registrations for risk of serious harm (RoSH) and other risks will be checked. Any risks which are no longer required or low risks will result in a deregistration being created. Registrations will be added or updated for active risks.\nNote: The service cannot infer all types of risk. Some risk registrations are manually added and maintained in Delius.\nRisk of serious harm\n\nOther risks\n\nInterfaces\nMessage formats\nThe service responds to HMPPS Domain Event messages via the Assessment Summary and Delius Queue. The events are raised by OASys to communicate the creation of an assessment of a person.\nExample messages are in the development source tree.\nIncoming messages are filtered on eventType by the SQS queue policy\n","url":"/"},"12":{"title":"AsyncAPI Reference","content":"AsyncAPI Reference\n\n\n\n.app-pane__content { position: relative }\n\ndocument.querySelector('main').parentElement.appendChild(document.querySelector('main \u003e iframe'))\n","url":"/asyncapi-reference.html"}}}