":{},"i":{"docs":{},"o":{"docs":{},"n":{"docs":{},"s":{"docs":{"12":{"ref":12,"tf":0.5882352941176471}}}}}}}}}}},"y":{"docs":{},"o":{"docs":{},"u":{"docs":{"12":{"ref":12,"tf":0.5882352941176471}}}}},"k":{"docs":{},"e":{"docs":{},"y":{"docs":{"13":{"ref":13,"tf":0.2702702702702703}}}}},"v":{"docs":{},"a":{"docs":{},"r":{"docs":{},"y":{"docs":{"13":{"ref":13,"tf":0.2702702702702703}}}}}}},"length":254},"corpusTokens":["1","a","about","access","access_token","accessing","add","adrs","allocations","an","and","any","api","approved","architectural","are","as","assessment","audit","auth","auth_token","authenticated","authentication","authorities","authorization","available","be","bearer","between","by","can","case","cases","channel","client","client_id:$client_secret","client_id=<hmpps","client_secret=<hmpps","collection","communicated","concepts","configured","confluence","contact","correct","court","create","creating","credentials","curl","custody","data","database","dates","dealt","decision","decisions","decode","delius","detailed","details","digital","domain","dropping","each","effective","email","endpoint","endpoints","ensure","event","events","existing","external","feel","find","flow","focused","follow","for","framework","free","from","get","github","guides","header","here","hmpps","how","https","id","in","in.hmpps.service.justice.gov.uk","incident","incidents","index","information","inspect","integration","integrations","interact","internal","into","is","issue","jq","jwt","key","licence","links","listening","live","location","make","making","manage","message","messages","monitor","more","name>.hmpps.service.justice.gov.uk","need","new","notes","oasys","oauth","obtained","of","offender","on","or","other","our","out","over","page","pages","pathfinder","perform","person","pingdom","plan","pom","post","posted","pre","premises","present","prison","probation","projects","proposal","provided","publishing","questions","r","read","recall","records","refer","registers","reports","repository","request","responsible","rest","reviews","risk","s","scopes","scores","search","secret","sending","sentence","server","service","services","should","sign","slack","small","soc","specific","status","submit","supplied","supplying","support","team","technical","that","the","then","these","tier","to","token","token?grant_type=client_credentials","tokens","touch","translations","typically","unpaid","uptime","us","user","using","vary","will","with","work","workforce","writing","x633793","you"],"pipeline":["trimmer"]}, "docs": {"11":{"title":"Guides","content":"How-To Guides\nMaking an Authenticated API Request\nAuthentication tokens can be obtained from the internal HMPPS OAuth server,\nHMPPS Auth, using Client\nCredentials Flow. Specific credentials for accessing an integration service\nare supplied by the ‘HMPPS Auth, Audit and Registers’ team. The client should\nbe configured with the correct scopes and authorities for accessing the API\nendpoints provided by the integration service and these will then be present\nin the supplied JWT.\n# Client credentials - supplied by 'HMPPS Auth, Audit and Registers' team\nCLIENT_ID=\u003chmpps-auth-client-id\u003e\nCLIENT_SECRET=\u003chmpps-auth-client-secret\u003e\n\n# Request a JWT access token\nAUTH_TOKEN=$(\n    curl -s --location \\\n        --request POST \"https://sign-in.hmpps.service.justice.gov.uk/auth/oauth/token?grant_type=client_credentials\" \\\n        --user \"$CLIENT_ID:$CLIENT_SECRET\" |\n        jq -r .access_token\n)\n\n# Inspect the JWT and ensure scopes and authorities are correct\njwt decode $AUTH_TOKEN\nTo make a request to the API submit a GET request to an endpoint in the\nintegration service, supplying the JWT access token as a bearer token in an\nAuthorization header.\ncurl -s --location https://\u003cintegration-service-name\u003e.hmpps.service.justice.gov.uk/case-details/X633793/1 \\\n        --header \"Authorization: Bearer $AUTH_TOKEN\"\n","url":"/guides.html"},"12":{"title":"Support","content":"Support\nYou can find more detailed technical information and Architectural Decision Records (ADRs) on our Confluence pages, or in our GitHub repository.\nStatus\nService uptime information is available on the Pingdom status page.\nAny live incidents will typically be dealt with and communicated over Slack.\nIncident reviews are posted on Confluence.\nContact us\nFor any other questions, feel free to get in touch with us by:\n\n\nDropping a message on our Slack channel,\nSending us an Email, or\nCreating a GitHub issue in our repository\n\n","url":"/support.html"},"13":{"title":"About","content":"About\nA collection of small, domain-focused integrations to support HMPPS Digital services that need to interact with\nprobation data. Typically, these integration services will perform translations between HMPPS and Delius domain\nconcepts, and are responsible for:\n\n\npublishing REST endpoints to read existing data from the Delius database\nlistening for HMPPS Domain Event messages and writing data into the Delius database\n\nServices\nFollow these links to find out more about each of our integration services.\n\n\nApproved Premises And Delius\nApproved Premises And OASys\nCourt Case And Delius\nCreate And Vary A Licence And Delius\nCustody Key Dates And Delius\nDomain Events And Delius\nEffective Proposal Framework And Delius\nMake Recall Decisions And Delius\nManage POM Cases And Delius\nOffender Events And Delius\nPathfinder And Delius\nPerson Search Index From Delius\nPre-Sentence Reports To Delius\nPrison Case Notes To Probation\nPrison Custody Status To Delius\nRefer And Monitor And Delius\nRisk Assessment Scores To Delius\nSentence Plan And Delius\nSentence Plan And Oasys\nSoc And Delius\nTier To Delius\nUnpaid Work And Delius\nWorkforce Allocations To Delius\nExternal Api And Delius\n^ add new projects here\n\n","url":"/"}}}