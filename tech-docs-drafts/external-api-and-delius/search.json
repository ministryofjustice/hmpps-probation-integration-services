ons","court","courtappearances","crn","custodial","custody","d","data","date","deleted","delius","delius.hmpps.service.justice.gov.uk","describe","description","dev","dev.hmpps.service.justice.gov.uk","display","documentation","does","dwelling","endpoint","escort","event","events","example","exist","exists","expiry","external","failuretocomplycount","false","fields","followed","following","for","forename","formats","freedom","from","get","guilty","h1","has","hmp","hmpps","https","if","important","in","inbreach","information","integration","is","keydates","length","lengthunits","licence","licenceconditions","likely","list","location","magistrates","maincategory","mainoffence","manchester","merged","middlename","movement","mri","mrihmp","must","n07a123","name","nametyperequireddescriptionschema","needs","none","not","note","notes","number","object","of","offence","offences","officercode","only","openapi","or","ora","order","parameterintyperequireddescription","parameters","path","plea","police","preprod","preprod.hmpps.service.justice.gov.uk","prisonbookingid","prisoncode","probation","prod","range","reading","recalldate","reference","relating","release","releasedate","removed","responses","responsibleofficer","schedule15sexualoffence","schedule15violentoffence","schemas","sed","sentence","servers","service","sharing","show","soft","some","specification","startdate","status","statusdescriptionschema","string","subcategory","surname","suspended","swagger","tailored","team","technical","that","the","these","this","threat","to","todo","true","type","ui","v1","violence","weeks","with","yaml"],"pipeline":["trimmer"]}, "docs": {"11":{"title":"API Reference","content":"\n    \n    API Reference\n\n\n.technical-documentation \u003e h1 { display: none !important }\nThe following documentation is also available in these formats:\n\n\nOpenAPI YAML\nSwagger UI\n\nAPI Reference v1\nAn example API specification for sharing Delius probation data with the HMPPS External API service.\n\n\n\n\n  Servers\n  \n    \n    \n    dev\n\n    \n    https://external-api-and-delius-dev.hmpps.service.justice.gov.uk\n  \n    \n    preprod\n\n    \n    https://external-api-and-delius-preprod.hmpps.service.justice.gov.uk\n  \n    \n    prod\n\n    \n    https://external-api-and-delius.hmpps.service.justice.gov.uk\n  \n  \n\n\n\n/case/{crn}/convictions\n\nget\n\n  Get a list of convictions (called “events” in Delius) for a probation case by CRN.\n\n\n  Note: This endpoint is only an example to show a range of fields that are available from Delius. \nSome fields are likely to be removed as the endpoint is tailored to the needs of the HMPPS Integration team.\n\n\n\n\nParameters\n\n\nParameterInTypeRequiredDescription\n\n\n\n\ncrn\npath\nstring\ntrue\nThe CRN (case reference number)\n\n\n\n\n\n\n\n\n\n\n\nResponses\n\n\nStatusDescriptionSchema\n\n\n\n\n200\n\nif the case exists\n\n\n\n{\n  \"convictions\": [\n    {\n      \"number\": 4,\n      \"active\": \"boolean\",\n      \"sentence\": {\n        \"description\": \"ORA Suspended Sentence Order\",\n        \"startDate\": \"string\",\n        \"length\": 16,\n        \"lengthUnits\": \"Weeks\"\n      },\n      \"mainOffence\": {\n        \"date\": \"string\",\n        \"code\": \"02802\",\n        \"description\": \"Burglary with violence or the threat of violence - 02802\",\n        \"schedule15SexualOffence\": \"boolean\",\n        \"schedule15ViolentOffence\": \"boolean\",\n        \"mainCategory\": {\n          \"code\": \"028\",\n          \"description\": \"Burglary in a dwelling\"\n        },\n        \"subCategory\": {\n          \"code\": \"02\",\n          \"description\": \"Burglary with violence or the threat of violence\"\n        }\n      },\n      \"additionalOffences\": [\n        {\n          \"date\": \"string\",\n          \"code\": \"02802\",\n          \"description\": \"Burglary with violence or the threat of violence - 02802\",\n          \"schedule15SexualOffence\": \"boolean\",\n          \"schedule15ViolentOffence\": \"boolean\",\n          \"mainCategory\": {\n            \"code\": \"028\",\n            \"description\": \"Burglary in a dwelling\"\n          },\n          \"subCategory\": {\n            \"code\": \"02\",\n            \"description\": \"Burglary with violence or the threat of violence\"\n          }\n        }\n      ],\n      \"courtAppearances\": [\n        {\n          \"appearanceType\": \"Sentence\",\n          \"appearanceDate\": \"string\",\n          \"convictionDate\": \"string\",\n          \"court\": \"Reading Magistrates Court\",\n          \"plea\": \"Guilty\"\n        }\n      ],\n      \"custody\": {\n        \"prisonBookingId\": \"12345A\",\n        \"status\": {\n          \"code\": \"D\",\n          \"description\": \"In custody\"\n        },\n        \"location\": {\n          \"code\": \"MRIHMP\",\n          \"name\": \"Manchester HMP\",\n          \"prisonCode\": \"MRI\"\n        },\n        \"keyDates\": [\n          {\n            \"type\": {\n              \"code\": \"SED\",\n              \"description\": \"Sentence Expiry Date\"\n            },\n            \"date\": \"string\"\n          }\n        ]\n      },\n      \"responsibleOfficer\": {\n        \"type\": \"string\",\n        \"officerCode\": \"N07A123\",\n        \"name\": {\n          \"forename\": \"string\",\n          \"middleName\": \"string\",\n          \"surname\": \"string\"\n        }\n      },\n      \"release\": {\n        \"releaseDate\": \"string\",\n        \"recallDate\": \"string\"\n      },\n      \"licenceConditions\": [\n        {\n          \"mainCategory\": \"Freedom of movement\",\n          \"subCategory\": \"Police escort\",\n          \"notes\": \"string\"\n        }\n      ],\n      \"breach\": {\n        \"failureToComplyCount\": 1,\n        \"inBreach\": \"boolean\"\n      }\n    }\n  ]\n}\n\n\n\n\n\n\n\n\n404\n\nif the case does not exist, has been soft-deleted, or merged\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\nSchemas\nEvent\n\n\n\n\nNameTypeRequiredDescriptionSchema\n\n\n\n\nnumber\nstring\nfalse\n\n\n  \n\n\n\n\nactive\nboolean\nfalse\n\n\n  \n\n\n\n\nsentence\nobject\nfalse\n\n\n  \n\n\n\n\nmainOffence\nobject\nfalse\n\n\n  Offence\n\n\n\n\nadditionalOffences\narray\nfalse\nList of additional offences\n\n\n  Offence\n\n\n\n\ncourtAppearances\narray\nfalse\n\n\n  \n\n\n\n\ncustody\nobject\nfalse\nInformation relating to custodial events\n\n\n  \n\n\n\n\nresponsibleOfficer\nobject\nfalse\n\n\n  \n\n\n\n\nrelease\nobject\nfalse\n\n\n  \n\n\n\n\nlicenceConditions\narray\nfalse\nList of licence conditions that must be followed after release\n\n\n  \n\n\n\n\nbreach\nobject\nfalse\n\n\n  \n\n\n\n\n\n\nOffence\n\n\n\n\nNameTypeRequiredDescriptionSchema\n\n\n\n\ndate\nstring\nfalse\n\n\n  \n\n\n\n\ncode\nstring\nfalse\n\n\n  \n\n\n\n\ndescription\nstring\nfalse\n\n\n  \n\n\n\n\nschedule15SexualOffence\nboolean\nfalse\n\n\n  \n\n\n\n\nschedule15ViolentOffence\nboolean\nfalse\n\n\n  \n\n\n\n\nmainCategory\nobject\nfalse\n\n\n  \n\n\n\n\nsubCategory\nobject\nfalse\n\n\n  \n\n\n\n\n\n\n\n","url":"/api-reference.html"},"13":{"title":"About","content":"external-api-and-delius\n// TODO Describe the service\n","url":"/"}}}